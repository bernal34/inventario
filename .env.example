# Cadena de conexión Postgres. En Supabase usa la URL del *Transaction pooler*
# (Settings -> Database -> Connection string -> Transaction pooler, puerto 6543).
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# Clave para firmar la sesión de Flask. Genera una larga y aleatoria.
INVENTARIO_SECRET_KEY=cambia-esta-clave-por-una-aleatoria-larga
